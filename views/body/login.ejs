<% layout("/layouts/boilerplate.ejs") %>

<div class="auth-wrapper">
  <div class="auth-card">
    <h2 class="text-center">Hey <span class="highlight">Mate!</span></h2>
    <p class="text-center auth-subtitle mb-4">Welcome back to Money Mate</p>

    <form action="/login" method="post" novalidate class="needs-validation">
      <div class="mb-3">
        <label for="username" class="form-label auth-label">Username</label>
        <input
          name="user[users]"
          placeholder="Enter Your Username here...."
          type="text"
          class="form-control custom-input"
          required
        />
        <div class="valid-feedback">Looks Great!</div>
        <div class="invalid-feedback">Something is Off !?</div>
      </div>

      <div class="mb-4">
        <label for="password" class="form-label auth-label">Password</label>
        <input
          name="user[pass]"
          placeholder="Enter Your Password here...."
          type="password"
          class="form-control custom-input"
          required
        />
        <div class="valid-feedback">Looks Great!</div>
        <div class="invalid-feedback">Something is Off !?</div>
      </div>

      <button class="btn main-cta w-100">Login to Dashboard</button>
    </form>
  </div>
</div>
